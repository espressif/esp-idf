# Change default offset to give more space for bootloader
CONFIG_PARTITION_TABLE_OFFSET=0xF000

# Secure Boot V2 - disable signing during build we must supply signatures at a later stage
CONFIG_SECURE_SIGNED_ON_BOOT=y
CONFIG_SECURE_SIGNED_ON_UPDATE=y
CONFIG_SECURE_BOOT_V2_RSA_ENABLED=y
CONFIG_SECURE_SIGNED_APPS_RSA_SCHEME=y
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_BOOT_V2_ENABLED=y
CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=n
CONFIG_SECURE_BOOT_INSECURE=y
CONFIG_SECURE_BOOT_FLASH_BOOTLOADER_DEFAULT=y

# Test of secure boot v2 multisig
CONFIG_SECURE_BOOT_V2_MIN_SIGNATURES=2
