#include "ld.common"
  .spm.text :
  {
    /* Code marked as running out of spm */
    _spm_text_start = ABSOLUTE(.);
    SECTION_MAPPINGS(spm_text)
    _spm_text_end = ABSOLUTE(.);
  } > spm_idram_seg

  .spm.data :
  {
    _spm_data_start = ABSOLUTE(.);
    SECTION_MAPPINGS(spm_data)
    _spm_data_end = ABSOLUTE(.);
  } > spm_idram_seg
